    "install:browsers": "npx playwright install chromium"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.0.0",
    "cloakbrowser": "^0.3.31",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0",
    "playwright": "^1.44.0",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^6.0.1",
    "typeorm": "^1.0.0",
    "uuid": "^14.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
