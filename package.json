{
  "name": "annas-api",
  "version": "1.0.0",
  "description": "Powerful book scraping API for Anna's Archive with bot-bypass, domain rotation, and intelligent caching",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsnd --respawn --transpile-only src/server.ts",
