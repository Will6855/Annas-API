# Anna's Archive API - Environment Configuration

# Server
PORT=3000
NODE_ENV=development

# Cache Configuration
CACHE_TYPE=memory          # Options: memory, redis
CACHE_TTL_SEARCH=300       # 5 minutes for search results
CACHE_TTL_BOOK=3600        # 1 hour for book details
CACHE_TTL_DOMAIN=600       # 10 minutes for domain health checks

# Redis (only needed if CACHE_TYPE=redis)
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=annas-api:

# Browser pool
BROWSER_POOL_SIZE=2         # Number of concurrent browser instances
BROWSER_TIMEOUT=30000       # Page load timeout (ms)
BROWSER_IDLE_TIMEOUT=120000 # Close idle browsers after (ms)

# Scraping
MAX_RETRIES=3               # Number of retry attempts per request
RETRY_DELAY=2000            # Delay between retries (ms)
REQUEST_TIMEOUT=25000       # Total request timeout (ms)

# Rate limiting
RATE_LIMIT_WINDOW=60000     # Window in ms (1 minute)
RATE_LIMIT_MAX=100          # Max requests per window
DEFAULT_RATE_LIMIT=100
DEFAULT_RATE_LIMIT_BOOK_DETAIL=30
DEFAULT_RATE_LIMIT_BOOK_DOWNLOAD=3
DEFAULT_RATE_LIMIT_BOOK_RELATED=30
DEFAULT_RATE_LIMIT_SEARCH=30

# Anna's Archive domains for rotation in scraping
ROTATION_DOMAINS=annas-archive.gl,annas-archive.org,annas-archive.se,annas-archive.gd,annas-archive.pk

# Logging
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://user:password@localhost:5432/annas_api

# Auth
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h
